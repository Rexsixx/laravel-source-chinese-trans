<?php
/**
 * Illuminate，DummyNamespace，动态类，存根，根据实际修改
 */

namespace DummyNamespace;

use Closure;

class DummyClass
{
    /**
     * Handle an incoming request.
	 * 处理传入的请求
     *
     * @param  \Illuminate\Http\Request  $request
     * @param  \Closure  $next
     * @return mixed
     */
    public function handle($request, Closure $next)
    {
        return $next($request);
    }
}
